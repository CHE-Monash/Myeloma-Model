# Simulated output data
analyses/*/simulated/*.dta
analyses/*/simulated/**/*.dta
analyses/*/simulated/report/
analyses/*/simulated/bootstrap/

# Simulated per-patient output CSVs (large; regenerate locally)
analyses/*/simulated/*.csv
analyses/*/simulated/**/*.csv

# Generated analysis results — figures/tables for the manuscript & appendix, not the repo
# (others reproduce by running the analyses; results regenerate locally)
analyses/*/results/*
!analyses/*/results/.gitkeep

# Cohort-construction & sample-size scripts (methods/appendix; not shipped)
analyses/transport_dvd/patients/sample_size/

# transport_dvd: WORK IN PROGRESS (DVd Calibrated Transport paper) — kept OFF GitHub
# until journal submission, then remove this line and tag a release. Local copy retained.
analyses/transport_dvd/

# Machine-specific local config (real paths; never committed — see config.example.do / env.example.sh)
/config.do
/env.sh

# Data-prep scripts (MRDR → model inputs). The model-input scripts, README and outputs (.mmat) are
# tracked. Scripts that operate on RAW MRDR data stay out of the repo (data-governance): the sub/
# helpers and data_extraction.do; plus restricted DATA and machine-specific paths (config.do).
prep/sub/
prep/data_extraction.do

# HPC: the generic .script job files under hpc/ ARE committed (collaborators reuse them; per-run args
# come from run.do + env.sh at submit time). Only the machine-specific cluster Stata config stays out.
# (hpc/_archive/ and hpc/.DS_Store are already covered by the global rules below.)
/hpc/config.do

# Large patient cohort & population data (exceed GitHub's 100MB limit; regenerate locally)
patients/*.dta
patients/*.csv
patients/*.xlsx
analyses/*/patients/*.dta

# Superseded analysis kept locally, off GitHub
analyses/td_pre/*

# Archived / superseded material (kept locally, out of Git) - all naming variants
**/_archive/
**/^archive/
**/archive/


#File types to ignore
.DS_Store
**/.DS_Store
*.log
*.smcl
*~.do
*.gph
*.bak
*.tmp

# Additional macOS system files
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows system files (if collaborating with Windows users)
Thumbs.db
Desktop.ini
ehthumbs.db

# Stata-specific temporary files
*.dta~
*.do~
*.ado~

# R session history (stray artifact; not repo content)
.Rhistory
**/.Rhistory

# Local editor/assistant config (machine-specific; not repo content)
.claude/settings.local.json

# Keep .gitkeep files (they won't be ignored by the above patterns)

